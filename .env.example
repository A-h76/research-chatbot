# ─── Core ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
FLASK_SECRET_KEY=change-me-to-a-long-random-string
# SQLite (default for local dev) or PostgreSQL for production
DATABASE_URL=sqlite:///chat_dev.db
# Either FLASK_ENV or APP_ENV (below) set to "production" enables Secure
# cookies — redundant on purpose, server.py checks both.
FLASK_ENV=development

# ─── Auth (Google OAuth) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated allow-list of emails (blank = anyone with a Google account)
ALLOWED_EMAILS=

# ─── DEV BYPASS (local development only) ─────────────────────────────────────
# Set this to any non-empty value to skip Google OAuth entirely.
# Visiting /login will automatically sign you in as dev@localhost.
# DELETE THIS LINE (or leave blank) before deploying to production.
DEV_AUTO_LOGIN=1

# ─── Models ──────────────────────────────────────────────────────────────────
DEFAULT_MODEL=gpt-4o-mini
UTILITY_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small
MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo

# ─── Uploads (Cloudflare R2 — S3-compatible object storage) ──────────────────
MAX_FILE_MB=25
# Per-user total storage quota, in MB (used by the storage-quota check).
MAX_STORAGE_MB=5000
# Max size for a single POST /api/documents/upload request, in MB.
MAX_DOCUMENT_UPLOAD_MB=50
R2_BUCKET=research-space
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# backend/storage's own provider choice (r2 | local | s3). Leave blank to
# auto-pick r2 when R2_BUCKET above is set, local otherwise.
STORAGE_BACKEND=

# ─── Queue worker (worker.py) ─────────────────────────────────────────────────
# How often (seconds) the worker polls upload_jobs for new work.
WORKER_POLL_INTERVAL=2
# Max jobs claimed per poll.
WORKER_BATCH_SIZE=10
# Attempts before a job is dead-lettered (marked failed for good).
WORKER_MAX_ATTEMPTS=5

# ─── Job-status cache (optional) ──────────────────────────────────────────────
# Never the source of truth (Postgres's upload_jobs row always is) — leave
# blank to skip caching entirely, no code path requires this.
REDIS_URL=

# ─── Email (Resend — optional) ───────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Research Workspace <onboarding@resend.dev>
SUPPORT_EMAIL=
APP_BASE_URL=http://localhost:5000

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to "production" to enable Secure cookies (requires HTTPS)
APP_ENV=development
