# ─── Core ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
FLASK_SECRET_KEY=change-me-to-a-long-random-string
# SQLite (default for local dev) or PostgreSQL for production
DATABASE_URL=sqlite:///chat_dev.db

# ─── Auth (Google OAuth) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated allow-list of emails (blank = anyone with a Google account)
ALLOWED_EMAILS=

# ─── DEV BYPASS (local development only) ─────────────────────────────────────
# Set this to any non-empty value to skip Google OAuth entirely.
# Visiting /login will automatically sign you in as dev@localhost.
# DELETE THIS LINE (or leave blank) before deploying to production.
DEV_AUTO_LOGIN=1

# ─── Models ──────────────────────────────────────────────────────────────────
DEFAULT_MODEL=gpt-4o-mini
UTILITY_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small
MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo

# ─── Uploads (Cloudflare R2 — S3-compatible object storage) ──────────────────
MAX_FILE_MB=25
R2_BUCKET=research-space
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─── Email (Resend — optional) ───────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Research Workspace <onboarding@resend.dev>
SUPPORT_EMAIL=
APP_BASE_URL=http://localhost:5000

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to "production" to enable Secure cookies (requires HTTPS)
APP_ENV=development
